# ---- LLM（Vercel AI SDK / DeepSeek）----
# Agent 默认走 deepseek-chat（V3，支持工具调用）。在 https://platform.deepseek.com 拿 key。
DEEPSEEK_API_KEY=sk-...
# 可选：覆盖模型 id（默认 deepseek-chat；推理模型 deepseek-reasoner 工具调用支持较弱）
KB_MODEL=deepseek-v4-flash

# ---- fastsearch 检索后端（本仓库的 Rust REST 服务）----
# 先在仓库根目录起服务：
#   FASTSEARCH_DATA=./data FASTSEARCH_KEYS="dev=:" cargo run -p fastsearch-server --bin fastsearch-server
FASTSEARCH_URL=http://127.0.0.1:8642
FASTSEARCH_API_KEY=dev
FASTSEARCH_COLLECTION=kb

# ---- 本地状态 ----
SQLITE_PATH=./data/kb.sqlite
PORT=8787
