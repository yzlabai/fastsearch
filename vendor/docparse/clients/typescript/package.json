{
  "name": "docparse-client",
  "version": "0.1.0",
  "description": "Thin TypeScript client for the docparse pure-Rust document parser (subprocess CLI or REST), with LangChain.js and Vercel AI SDK adapters",
  "license": "Apache-2.0",
  "homepage": "https://github.com/yzlabai/docparse-rs/tree/main/clients/typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yzlabai/docparse-rs.git",
    "directory": "clients/typescript"
  },
  "bugs": {
    "url": "https://github.com/yzlabai/docparse-rs/issues"
  },
  "keywords": [
    "docparse",
    "pdf",
    "document-parsing",
    "rag",
    "chunking",
    "ocr",
    "langchain",
    "llamaindex",
    "markdown",
    "ai"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test \"test/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "comment:dependencies": "Deliberately ZERO runtime dependencies. The subprocess client wraps the docparse binary; the HTTP client uses global fetch/FormData (Node >=18). Framework hosts are optional peers, imported lazily.",
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "ai": ">=3.0.0",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": { "optional": true },
    "ai": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
